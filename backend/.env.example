# backend 环境变量示例（复制为 .env 后填入真实值）
DB_DSN=postgres://learning:learning@localhost:5432/learning_buddy?sslmode=disable
REDIS_ADDR=localhost:6379
JWT_SECRET=change-me
AGENT_BASE_URL=http://localhost:8000
AGENT_SHARED_SECRET=replace-with-the-same-random-secret-on-both-services
CHAT_RATE_LIMIT_PER_MIN=20
PLAN_RATE_LIMIT_PER_MIN=10
QUIZ_RATE_LIMIT_PER_MIN=10
CHAT_DAILY_TOKEN_LIMIT=100000
PLAN_DAILY_TOKEN_LIMIT=100
QUIZ_DAILY_TOKEN_LIMIT=100
PARSE_ALERT_WEBHOOK_URL=
MINIO_ENDPOINT=localhost:9000
# Backend 容器连接使用 MINIO_ENDPOINT；浏览器签名 URL 使用可公开解析的端点。
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SOURCE_BUCKET=materials-source
MINIO_DERIVED_BUCKET=materials-derived
MINIO_SECURE=false
MINIO_PUBLIC_SECURE=false
MINIO_REGION=us-east-1
ASSET_URL_TTL_SECONDS=600
EMBEDDING_DIM=1024
ADDR=:8080
