# agent 环境变量示例（复制为 .env 后填入真实值）
LLM_API_KEY=your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# Parser 最小权限账号：读 materials 归属/状态，更新 content，读写 material_chunks。
PG_DSN=postgres://learning_parser:change-me@localhost:5432/learning_buddy
REDIS_ADDR=localhost:6379
REDIS_TIMEOUT_S=0.2
AGENT_SHARED_SECRET=replace-with-the-same-random-secret-on-both-services
# 逗号分隔的可信浏览器来源；生产留空（Agent 仅接受 Backend 内部调用）。
CORS_ORIGINS=

# 嵌入（Embedding）—— DashScope text-embedding-v4（1024 维）
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your-dashscope-key
EMBEDDING_BASE_URL=https://llm-h85dzp0s5asc2v6i.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
RETRIEVER_TIMEOUT_S=0.7
PARSER_EMBEDDING_TIMEOUT_S=30
TUTOR_TIMEOUT_S=30

# Query Rewrite / Rerank / OCR-VL（均可替换为 OpenAI 兼容端点）
QUERY_REWRITE_TIMEOUT_S=0.8
RERANK_TIMEOUT_S=1.2
RERANK_API_KEY=your-dashscope-key
# 将 <workspace-id> 替换为百炼业务空间 ID；自建兼容代理可覆盖为自己的端点。
RERANK_BASE_URL=https://<workspace-id>.cn-beijing.maas.aliyuncs.com/compatible-api/v1/reranks
RERANK_MODEL=qwen3-rerank
RERANK_MAX_DOCUMENT_TOKENS=4000
VISION_API_KEY=your-dashscope-key
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-ocr
# 原始图片默认不发送到远端；仅对已确认可发送的非敏感数据或受控内网模型显式开启。
VISION_ALLOW_RAW_IMAGES=false

# Parser 对象存储账号在生产仅授予：读 source、写 derived。
MINIO_ENABLED=true
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_SOURCE_BUCKET=materials-source
MINIO_DERIVED_BUCKET=materials-derived
RAG_INDEX_VERSION=rag-v2
PARSER_VERSION=rag-v2
CLEANING_RULES_VERSION=2026-07-v1
MAX_CHUNK_TOKENS=3000
CHUNK_OVERLAP_TOKENS=300
SHORT_DOCUMENT_CHARS=5000
MAX_CONTEXT_TOKENS=12000

PORT=8000
